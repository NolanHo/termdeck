{
  "name": "termdeck",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "bin": {
    "termdeck": "./bin/termdeck.js",
    "termdeckd": "./bin/termdeckd.js"
  },
  "scripts": {
    "gen": "buf generate",
    "dev:daemon": "tsx src/daemon.ts",
    "dev:cli": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "tsx --test tests/*.test.ts",
    "prepack": "pnpm run build",
    "start:daemon": "node dist/daemon.js",
    "postinstall": "node scripts/install-check.mjs"
  },
  "files": [
    "bin",
    "dist",
    "proto",
    "scripts",
    "docs",
    "README.md",
    "README_zh.md",
    "LICENSE"
  ],
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^5.5.0",
    "@xterm/xterm": "^6.0.0",
    "commander": "^14.0.2",
    "node-pty": "^1.0.0",
    "strip-ansi": "^7.2.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.69.0",
    "@bufbuild/protoc-gen-es": "^2.12.0",
    "@types/node": "^25.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.3.0",
    "node-gyp": "^12.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "description": "Persistent PTY terminal sessions for automation agents with CLI control and observe-only web replay",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NolanHo/termdeck.git"
  },
  "homepage": "https://github.com/NolanHo/termdeck#readme",
  "bugs": {
    "url": "https://github.com/NolanHo/termdeck/issues"
  },
  "keywords": [
    "pty",
    "terminal",
    "daemon",
    "cli",
    "automation",
    "agents",
    "xterm",
    "protobuf"
  ]
}
